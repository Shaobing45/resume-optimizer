# ============================================
# AI简历优化 — 环境变量配置
# 复制此文件为 .env.local 并填入真实值
# ============================================

# -------- AI API（必填）--------
# OpenAI API Key（或兼容API的密钥）
# DeepSeek: https://platform.deepseek.com/api_keys
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# 可选：兼容的 API 地址
# AI_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-chat

# -------- 管理员密码（必填）--------
# 用于 /admin 后台确认付款，务必修改！
ADMIN_PASSWORD=change-me-please

# -------- 可选 --------
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# -------- SEO 验证（可选）--------
# 百度站长验证码
# BAIDU_VERIFICATION=code-here
# Google 站长验证码
# GOOGLE_VERIFICATION=code-here

# -------- 通知服务（可选）--------
# Server酱（微信推送），注册地址：https://sct.ftqq.com
# 配置后，有新订单和确认收款时会通过微信通知
# SERVERCHAN_KEY=sctp-your-key-here
